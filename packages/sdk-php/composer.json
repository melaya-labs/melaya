{
    "name": "melaya/sdk",
    "description": "Official Melaya PHP SDK — unified market data, strategies, backtesting, and streaming.",
    "type": "library",
    "license": "MIT",
    "keywords": ["melaya", "trading", "market-data", "crypto", "sdk"],
    "homepage": "https://melaya.org",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Melaya\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Melaya\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
